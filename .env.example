# Edict Guardian - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application
# =============================================================================
APP_NAME=edict-guardian
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/edict_guardian
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=edict-guardian-documents

# =============================================================================
# OCR Configuration
# =============================================================================
TESSERACT_LANG=spa
OCR_CONFIDENCE_THRESHOLD=0.7
ENABLE_TEXTRACT_FALLBACK=true

# =============================================================================
# NLP Configuration
# =============================================================================
SPACY_MODEL=es_core_news_lg

# =============================================================================
# Notifications
# =============================================================================
# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@edictguardian.com

# =============================================================================
# Security
# =============================================================================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Crawler
# =============================================================================
CRAWLER_USER_AGENT=EdictGuardian/1.0 (Legal Notification System)
CRAWLER_TIMEOUT=30
CRAWLER_MAX_RETRIES=3

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Development
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
