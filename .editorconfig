# EditorConfig - https://editorconfig.org
# Helps maintain consistent coding style across different editors and IDEs

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python files
[*.py]
indent_size = 4
max_line_length = 100

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# TOML files
[*.toml]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Makefiles (require tabs)
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 2

# Docker files
[Dockerfile*]
indent_size = 2

# Configuration files
[.editorconfig]
indent_size = 2

[.gitignore]
indent_size = 2

[.dockerignore]
indent_size = 2

[.pre-commit-config.yaml]
indent_size = 2

# HTML/CSS/JS (if any frontend files)
[*.{html,css,js,ts}]
indent_size = 2
